# Copy to .env (gitignored) and fill in. The Makefile auto-loads it.
# SECRETS ONLY — non-secret infra config (region, CIDRs, registry name) lives in
# terraform/envs/doks.tfvars. Use plain KEY=value, NO quotes (Makefile `include`).

# DigitalOcean API token — ONE token used by both Terraform and doctl/docker.
# The Makefile maps it to TF_VAR_do_token (Terraform) and DIGITALOCEAN_ACCESS_TOKEN (doctl).
# Use a FRESH token scoped to a dedicated DO project (revoke any previously-shared one).
DO_TOKEN=

# --- optional / later phases ---
# VulnBank AI chatbot. Leave EMPTY for deterministic mock mode (recommended for the bench).
DEEPSEEK_API_KEY=
# Phase 4 Tier-2 LLM-judge matcher.
ANTHROPIC_API_KEY=
